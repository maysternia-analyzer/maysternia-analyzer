# Майстерня скілів — Аналізатор записів
# Скопіюй цей файл як .env і заповни свої ключі

# OpenAI API ключ (для транскрипції через Whisper)
# Отримати на: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic API ключ (для аналізу через Claude)
# Отримати на: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Модель Claude для аналізу чек-лістів
ANTHROPIC_MODEL=claude-sonnet-4-6

# Секретний ключ Flask (можна залишити як є або змінити)
SECRET_KEY=maysternia-secret-key-2024

# Опційно: Zoom-автосинхронізація. Для ручного завантаження файлів це не потрібно.
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# ZOOM_WEBHOOK_SECRET=
